{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash

# run_once_install-packages.sh.tmpl
# This script runs only when the hash of this file changes.
# Fixed line endings

# Configuration URLs (can be overridden via environment variables)
TAILSCALE_INSTALL_URL="${TAILSCALE_URL:-https://tailscale.com/install.sh}"
STARSHIP_INSTALL_URL="${STARSHIP_URL:-https://starship.rs/install.sh}"
BITWARDEN_CLI_URL="${BW_CLI_URL:-https://vault.bitwarden.com/download/?app=cli&platform=linux}"
NERD_FONT_URL="${NERD_FONT_URL:-https://github.com/ryanoasis/nerd-fonts/releases/latest/download/FiraCode.zip}"

set -eu
# Bash-specific features are used (like [[), so pipefail is acceptable
set -o pipefail

echo "Starting Linux Package Installation..."

# Function to check if a command exists
command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# Function to validate package installation
validate_package_installation() {
    local package="$1"
    local package_manager="$2"

    if [ "$package_manager" = "apt" ]; then
        if ! dpkg -l "$package" >/dev/null 2>&1; then
            echo "Error: Package $package failed to install via apt"
            return 1
        fi
    elif [ "$package_manager" = "dnf" ]; then
        if ! rpm -q "$package" >/dev/null 2>&1; then
            echo "Error: Package $package failed to install via dnf"
            return 1
        fi
    fi
    return 0
}

# Function to validate service status
validate_service_status() {
    local service="$1"
    local service_manager="$2"

    if [ "$service_manager" = "systemd" ]; then
        if ! systemctl is-active --quiet "$service"; then
            echo "Error: Service $service is not running"
            return 1
        fi
    fi
    return 0
}

# Function to validate and report package installation failures
validate_all_packages() {
    local package_manager="$1"
    shift
    local packages="$@"
    local failed=0

    for pkg in $packages; do
        if [[ "$pkg" == "starship" ]]; then
            continue
        fi
        if ! validate_package_installation "$pkg" "$package_manager"; then
            failed=$((failed + 1))
        fi
    done

    if [ $failed -gt 0 ]; then
        echo "Warning: $failed package(s) failed to install"
        return 1
    fi
    echo "All packages installed successfully"
    return 0
}

# Check if sudo is available (should be pre-authorized by install.sh)
# If not available, skip package installation
HAVE_SUDO=false
if command_exists sudo && sudo -n true 2>/dev/null; then
    HAVE_SUDO=true
else
    echo "Warning: sudo not available or not pre-authorized. Package installation will be skipped."
    echo "This usually means you need to log out and log back in after adding user to sudo group."
fi

# Pre-install Tailscale via official script if missing
if ! command_exists tailscale; then
    echo "Tailscale not found. Running official installer to setup repos..."
    if ! curl -fsSL "$TAILSCALE_INSTALL_URL" | sh; then
        echo "Warning: Tailscale installer exited with error. Checking if tailscale binary is available..."
        if command_exists tailscale; then
            echo "Tailscale binary found despite installer error. Continuing."
        else
            echo "Warning: Tailscale not installed. Run 'curl -fsSL https://tailscale.com/install.sh | sh' manually."
        fi
    fi
fi

# Load package data based on OS family
{{ $pkgData := include "packages.yaml" | fromYaml }}
{{ $linuxData := $pkgData.linux }}

# Detect distribution and package manager
DISTRO_FAMILY=""
PKG_MGR_CMD=""
if command -v apt-get >/dev/null 2>&1; then
    DISTRO_FAMILY="debian"
    PKG_MGR_CMD="apt"
elif command -v dnf >/dev/null 2>&1; then
    DISTRO_FAMILY="fedora"
    PKG_MGR_CMD="dnf"
fi

echo "Detected package manager: $PKG_MGR_CMD (OS family: $DISTRO_FAMILY)"

# Repository configuration based on OS family
if [ "$PKG_MGR_CMD" = "dnf" ]; then
    # Fedora: Enable RPM Fusion repositories for proprietary software
{{ if .is_workstation }}
    echo "Detected Fedora with workstation role. Setting up RPM Fusion repositories..."
    if [ "$HAVE_SUDO" = true ]; then
        setup_rpm_fusion() {
            if sudo dnf repolist 2>/dev/null | grep -q "rpmfusion"; then
                echo "RPM Fusion repositories already enabled"
                return 0
            fi
            echo "Installing RPM Fusion repositories..."
            sudo dnf install -y \
                https://mirrors.rpmfusion.org/free/fedora/rpmfusion-free-release-$(rpm -E %fedora).noarch.rpm \
                https://mirrors.rpmfusion.org/nonfree/fedora/rpmfusion-nonfree-release-$(rpm -E %fedora).noarch.rpm
            sudo dnf config-manager --set-enabled fedora-cisco-openh264 2>/dev/null || true
            echo "RPM Fusion repositories enabled successfully"
        }
        setup_rpm_fusion
    else
        echo "Skipping RPM Fusion setup (no sudo access)"
    fi
{{ end }}
elif [ "$PKG_MGR_CMD" = "apt" ]; then
    # Debian/Ubuntu: Enable non-free repositories for Interactive roles on Debian ONLY (not Ubuntu)
{{ if .is_workstation }}
    if [ -f /etc/debian_version ] && [ ! -f /etc/lsb-release ]; then
        echo "Detected Debian. Ensuring non-free repositories are enabled..."
        if [ "$HAVE_SUDO" = true ]; then
            if ! grep -q "non-free" /etc/apt/sources.list 2>/dev/null; then
                sudo sed -i 's/main$/main contrib non-free non-free-firmware/g' /etc/apt/sources.list
                echo "Non-free repositories added to sources.list"
            else
                echo "Non-free repositories already enabled"
            fi
        else
            echo "Skipping non-free setup (no sudo access)"
        fi
    fi
{{ end }}
fi

# Update package lists
if [ "$PKG_MGR_CMD" = "apt" ]; then
    echo "Updating apt repositories..."
    if [ "$HAVE_SUDO" = true ]; then
        sudo apt-get update
    else
        echo "Skipping apt update (no sudo access)"
    fi
elif [ "$PKG_MGR_CMD" = "dnf" ]; then
    echo "Updating dnf repositories..."
    if [ "$HAVE_SUDO" = true ]; then
        sudo dnf makecache --refresh
    else
        echo "Skipping dnf makecache (no sudo access)"
    fi
fi

# Get package manager configuration (for reference)
# Note: This is template-time only; runtime uses DISTRO_FAMILY and PKG_MGR_CMD
{{- $pkgMgrData := $linuxData.package_managers }}

# Define minimal base packages (String list for POSIX compatibility)
PACKAGES=""

# Build package list based on detected distribution family
if [ "$DISTRO_FAMILY" = "debian" ]; then
{{- $osPkgData := $linuxData.debian }}
    # Common packages
{{- range $osPkgData.common }}
    PACKAGES="$PACKAGES {{ . }}"
{{- end }}

    # Core Tools (Excluded from headless 'server' roles to save resources)
    # Only install 'extras' (Neovim, Ripgrep, Starship) on Interactive roles:
{{- if .is_workstation }}
{{- range $osPkgData.extras }}
    PACKAGES="$PACKAGES {{ . }}"
{{- end }}
{{- end }}

    # Role-specific packages
{{- if hasKey $osPkgData.roles .role }}
{{-   $rolePkgs := index $osPkgData.roles .role }}
{{-   if $rolePkgs }}
{{-     range $rolePkgs }}
    PACKAGES="$PACKAGES {{ . }}"
{{-     end }}
{{-   end }}
{{- end }}
elif [ "$DISTRO_FAMILY" = "fedora" ]; then
{{- $osPkgData := $linuxData.fedora }}
    # Common packages
{{- range $osPkgData.common }}
    PACKAGES="$PACKAGES {{ . }}"
{{- end }}

    # Core Tools (Excluded from headless 'server' roles to save resources)
    # Only install 'extras' (Neovim, Ripgrep, Starship) on Interactive roles:
{{- if .is_workstation }}
{{- range $osPkgData.extras }}
    PACKAGES="$PACKAGES {{ . }}"
{{- end }}
{{- end }}

    # Role-specific packages
{{- if hasKey $osPkgData.roles .role }}
{{-   $rolePkgs := index $osPkgData.roles .role }}
{{-   if $rolePkgs }}
{{-     range $rolePkgs }}
    PACKAGES="$PACKAGES {{ . }}"
{{-     end }}
{{-   end }}
{{- end }}
fi

# Apply package name mappings for Fedora
{{- $mappings := $linuxData.package_mappings }}
if [ "$DISTRO_FAMILY" = "fedora" ]; then
    declare -A PKG_ALIASES=()
{{- range $key, $val := $mappings }}
    PKG_ALIASES["{{ $key }}"]="{{ $val.fedora }}"
{{- end }}
    for alias in "${!PKG_ALIASES[@]}"; do
        PACKAGES=$(echo "$PACKAGES" | sed "s/\b$alias\b/${PKG_ALIASES[$alias]}/g")
    done
fi

echo "Installing packages: $PACKAGES"

# Install packages based on package manager
if [ "$PKG_MGR_CMD" = "apt" ]; then
    # Warning: unquoted variable to allow splitting.
    # Filter out 'starship' since it's installed via script, not apt.
    APT_PACKAGES=$(echo $PACKAGES | sed 's/starship//g')

    # Install packages
    if [ "$HAVE_SUDO" = true ]; then
        echo "Installing packages via apt-get..."
        sudo apt-get install -y $APT_PACKAGES
        validate_all_packages "apt" $APT_PACKAGES
    else
        echo "Skipping package installation (no sudo access)"
        echo "Please install manually with:"
        echo "  sudo apt-get install -y $APT_PACKAGES"
    fi
elif [ "$PKG_MGR_CMD" = "dnf" ]; then
    # Separate regular packages from DNF groups
    REGULAR_PACKAGES=""
    GROUP_PACKAGES=""

    for pkg in $PACKAGES; do
        if [[ "$pkg" == starship ]]; then
            continue  # Skip starship, installed via script
        elif [[ "$pkg" == @* ]]; then
            # This is a DNF group
            GROUP_PACKAGES="$GROUP_PACKAGES $pkg"
        else
            REGULAR_PACKAGES="$REGULAR_PACKAGES $pkg"
        fi
    done

    if [ "$HAVE_SUDO" = true ]; then
        # Install regular packages
        if [ -n "$REGULAR_PACKAGES" ]; then
            echo "Installing packages via dnf..."
            sudo dnf install -y $REGULAR_PACKAGES
            validate_all_packages "dnf" $REGULAR_PACKAGES
        fi

        # Install DNF groups
        if [ -n "$GROUP_PACKAGES" ]; then
            echo "Installing DNF groups via dnf..."
            sudo dnf groupinstall -y $GROUP_PACKAGES
        fi
    else
        echo "Skipping package installation (no sudo access)"
        echo "Please install manually with:"
        echo "  sudo dnf install -y $REGULAR_PACKAGES"
        echo "  sudo dnf groupinstall -y $GROUP_PACKAGES"
    fi
else
    echo "Warning: No supported package manager found. Skipping package installation via package manager."
fi

# Install Starship ONLY for Interactive roles (Save RAM/Disk)
# Install Starship if specifically requested in packages.yaml (installed via script, not apt/dnf)
if [[ "$PACKAGES" == *"starship"* ]]; then
    if ! command_exists starship; then
        echo "Installing Starship..."
        curl -sS "$STARSHIP_INSTALL_URL" | sh -s -- -y
    else
        echo "Starship already installed."
    fi
fi

# Install Bitwarden CLI if not present
if ! command_exists bw; then
    echo "Installing Bitwarden CLI..."
    # Download the native binary
    curl -L "$BITWARDEN_CLI_URL" -o bw.zip
    unzip -o bw.zip
    chmod +x bw
    mkdir -p "$HOME/.local/bin"
    mv bw "$HOME/.local/bin/bw"
    rm bw.zip
fi

# Install FiraCode Nerd Font for Interactive roles
{{- if .is_workstation }}
    FONT_DIR="$HOME/.local/share/fonts"
    # Check if font already exists to avoid re-downloading
    if [[ ! -f "$FONT_DIR/FiraCodeNerdFont-Regular.ttf" ]]; then
        echo "Installing FiraCode Nerd Font..."
        mkdir -p "$FONT_DIR"

        # Ensure unzip is available
        if ! command_exists unzip; then
             if [ "$PKG_MGR_CMD" = "apt" ]; then
                 echo "Installing unzip for font extraction..."
                 sudo apt-get install -y unzip
             elif [ "$PKG_MGR_CMD" = "dnf" ]; then
                 echo "Installing unzip for font extraction..."
                 sudo dnf install -y unzip
             fi
        fi

        # Download and install
        curl -fLo "/tmp/FiraCode.zip" "$NERD_FONT_URL"
        unzip -o -q "/tmp/FiraCode.zip" -d "$FONT_DIR"
        rm "/tmp/FiraCode.zip"

        # Install fontconfig for fc-cache if not available
        if ! command_exists fc-cache; then
            if [ "$PKG_MGR_CMD" = "apt" ]; then
                echo "Installing fontconfig for font cache management..."
                sudo apt-get install -y fontconfig
            elif [ "$PKG_MGR_CMD" = "dnf" ]; then
                echo "Installing fontconfig for font cache management..."
                sudo dnf install -y fontconfig
            fi
        fi

        if command_exists fc-cache; then
            echo "Updating font cache..."
            fc-cache -f "$FONT_DIR"
        else
            echo "Warning: fc-cache not available. Font cache not updated."
        fi
        echo "FiraCode Nerd Font installed successfully."
    else
        echo "FiraCode Nerd Font already installed."
    fi
{{- end }}

{{ if and (eq .chezmoi.os "linux") .is_workstation }}
# Configure ibus-unikey GNOME input source after package install
if grep -qiE "^ID(_LIKE)?=.*fedora" /etc/os-release 2>/dev/null; then
    if rpm -q ibus-unikey >/dev/null 2>&1; then
        CURRENT_SOURCES=$(gsettings get org.gnome.desktop.input-sources sources 2>/dev/null || echo "[]")
        if echo "$CURRENT_SOURCES" | grep -q "Unikey"; then
            echo "ibus-unikey already in GNOME input sources."
        else
            echo "Adding ibus-unikey to GNOME input sources..."
            if [ "$CURRENT_SOURCES" = "@a(ss) []" ] || [ "$CURRENT_SOURCES" = "[]" ]; then
                gsettings set org.gnome.desktop.input-sources sources "[('xkb', 'us'), ('ibus', 'Unikey')]"
            else
                NEW_SOURCES=$(echo "$CURRENT_SOURCES" | sed "s/]$/, ('ibus', 'Unikey')]/")
                gsettings set org.gnome.desktop.input-sources sources "$NEW_SOURCES"
            fi
            echo "ibus-unikey added. Switch input with Super+Space."
        fi
    fi
fi
{{ end }}

echo "Linux Package Installation Complete!"
{{ end }}
