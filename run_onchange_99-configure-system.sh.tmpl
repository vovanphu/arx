{{- if eq .chezmoi.os "linux" -}}
#!/bin/bash
# run_onchange_99-configure-system.sh.tmpl (Updated: 2026-03-04 01:28)

TARGET_NAME="{{ .hostname }}"
CURRENT_NAME=$(hostname)

echo "--- System Configuration ---"

# Function to check if running as root
is_root() {
    [ "$(id -u)" -eq 0 ]
}

# Function to validate service status
validate_service_status() {
    local service="$1"
    local service_manager="$2"

    if [ "$service_manager" = "systemd" ]; then
        if ! systemctl is-active --quiet "$service"; then
            echo "Error: Service $service is not running"
            return 1
        fi
    elif [ "$service_manager" = "sysvinit" ]; then
        if ! systemctl is-active --quiet "$service"; then
            echo "Error: Service $service is not running"
            return 1
        fi
    fi
    return 0
}

# Function to validate package installation
validate_package_installation() {
    local package="$1"
    local package_manager="$2"

    if [ "$package_manager" = "apt" ]; then
        if ! dpkg -l "$package" >/dev/null 2>&1; then
            echo "Error: Package $package failed to install via apt"
            return 1
        fi
    elif [ "$PKG_MGR" = "dnf" ]; then
        if ! rpm -q "$package" >/dev/null 2>&1; then
            echo "Error: Package $package failed to install via dnf"
            return 1
        fi
    fi
    return 0
}


# 1. Tailscale Configuration (Automatic)
if command -v tailscale >/dev/null 2>&1; then
    echo "Found Tailscale. Checking status..."

    # WSL-specific check: Do not mess with resolv.conf on WSL.
    # It causes "Temporary failure in name resolution" because Tailscale and WSL's internal vSwitch conflict.
    if grep -iq "microsoft" /proc/version 2>/dev/null || grep -iq "wsl" /proc/version 2>/dev/null; then
        echo "WSL detected. Skipping resolv.conf modifications to prevent DNS breakage."
    fi

    # Check if logged in (status returns exit code 1 if not running/logged out usually)
    if ! tailscale status >/dev/null 2>&1; then
        echo "Tailscale is not logged in. Attempting auto-auth via Bitwarden..."

        if [ -n "$BW_SESSION" ]; then
             TS_KEY=$(bw get password "tailscale-auth-key")
             if [ -n "$TS_KEY" ]; then
                 TS_UP_FLAGS="--authkey $TS_KEY --hostname $TARGET_NAME --accept-routes"
                 # WSL-specific: Disable DNS hijacking to prevent "Temporary failure in name resolution"
                 if grep -iq "microsoft" /proc/version 2>/dev/null || grep -iq "wsl" /proc/version 2>/dev/null; then
                     TS_UP_FLAGS="$TS_UP_FLAGS --accept-dns=false"
                 fi

                 echo "Tailscale Auth Key retrieved. Authenticating as '$TARGET_NAME'..."
                 if is_root; then
                     tailscale up $TS_UP_FLAGS
                 else
                     sudo tailscale up $TS_UP_FLAGS
                 fi
                 echo "Tailscale Connected Successfully!"
             else
                 echo "Warning: Retrieved empty Tailscale key."
             fi
        else
            echo "Warning: Bitwarden session not active. Skipping Tailscale auto-login."
        fi
    else
        echo "Tailscale is already logged in. Updating hostname preference..."
        if is_root; then
            tailscale set --hostname "$TARGET_NAME"
        else
            sudo tailscale set --hostname "$TARGET_NAME"
        fi
    fi
fi


# 2.1 WSL Specific Hostname persistence block (Always ensure wsl.conf is correct)
if grep -iq "microsoft" /proc/version 2>/dev/null || grep -iq "wsl" /proc/version 2>/dev/null; then
    echo -e "\033[33mWSL Environment detected. Ensuring /etc/wsl.conf is correct...\033[0m"
    WSL_CONF_UPDATED=false
    # Inject network section if it doesn't exist
    if ! grep -iq "\[network\]" /etc/wsl.conf 2>/dev/null; then
        if is_root; then echo -e "\n[network]" >> /etc/wsl.conf; else echo -e "\n[network]" | sudo tee -a /etc/wsl.conf > /dev/null; fi
    fi
    
    # Note: We NO LONGER manually set hostname=... in wsl.conf.
    # We let Windows handle the OS hostname while using $TARGET_NAME purely for Tailscale.
    if grep -iq "hostname[[:space:]]*=" /etc/wsl.conf 2>/dev/null; then
        echo "Removing manual hostname entry from /etc/wsl.conf..."
        if is_root; then sed -i '/^hostname[[:space:]]*=/d' /etc/wsl.conf; else sudo sed -i '/^hostname[[:space:]]*=/d' /etc/wsl.conf; fi
        WSL_CONF_UPDATED=true
    fi
    
    # Enable auto-generation of hosts file (Default WSL behavior)
    if ! grep -iq "generateHosts[[:space:]]*=" /etc/wsl.conf 2>/dev/null; then
        if is_root; then sed -i '/\[network\]/a generateHosts=true' /etc/wsl.conf; else echo -e "generateHosts=true" | sudo tee -a /etc/wsl.conf > /dev/null; fi
        WSL_CONF_UPDATED=true
    else
        # Ensure it's set to true
        if is_root; then sed -i 's/^generateHosts[[:space:]]*=.*/generateHosts=true/' /etc/wsl.conf; else sudo sed -i 's/^generateHosts[[:space:]]*=.*/generateHosts=true/' /etc/wsl.conf; fi
        WSL_CONF_UPDATED=true
    fi

    # Enable auto-generation of resolv.conf (Default WSL behavior)
    if ! grep -iq "generateResolvConf[[:space:]]*=" /etc/wsl.conf 2>/dev/null; then
        if is_root; then sed -i '/\[network\]/a generateResolvConf=true' /etc/wsl.conf; else echo -e "generateResolvConf=true" | sudo tee -a /etc/wsl.conf > /dev/null; fi
        WSL_CONF_UPDATED=true
    else
        # Ensure it's set to true
        if is_root; then sed -i 's/^generateResolvConf[[:space:]]*=.*/generateResolvConf=true/' /etc/wsl.conf; else sudo sed -i 's/^generateResolvConf[[:space:]]*=.*/generateResolvConf=true/' /etc/wsl.conf; fi
        WSL_CONF_UPDATED=true
    fi

    # Restore native resolv.conf symlink if auto-generation is enabled
    if grep -iq "generateResolvConf[[:space:]]*=[[:space:]]*true" /etc/wsl.conf 2>/dev/null; then
        if [ ! -L /etc/resolv.conf ] || [ ! -e /etc/resolv.conf ]; then
            echo "Removing custom /etc/resolv.conf to allow WSL auto-generation..."
            if is_root; then
                chattr -i /etc/resolv.conf 2>/dev/null
                rm -f /etc/resolv.conf
            else
                sudo chattr -i /etc/resolv.conf 2>/dev/null
                sudo rm -f /etc/resolv.conf
            fi
            WSL_CONF_UPDATED=true
        fi
    fi

    if [ "$WSL_CONF_UPDATED" = true ]; then
        echo -e "\033[33m/etc/wsl.conf updated. You MUST restart WSL ('wsl --shutdown' in Windows) for changes to take effect.\033[0m"
    fi
fi

# 3. SSH Server Configuration (auto-start for all Linux systems)
if command -v sshd >/dev/null 2>&1; then
    echo "Checking SSH server status..."

    # Check if SSH service is running
    if ! systemctl is-active --quiet ssh 2>/dev/null && ! systemctl is-active --quiet sshd 2>/dev/null; then
        echo "SSH server is not running. Starting service..."
        SSH_STARTED=false
        if is_root; then
            if systemctl start ssh 2>/dev/null || systemctl start sshd 2>/dev/null || service ssh start 2>/dev/null; then
                SSH_STARTED=true
            fi
            systemctl enable ssh 2>/dev/null || systemctl enable sshd 2>/dev/null || true
        else
            if sudo systemctl start ssh 2>/dev/null || sudo systemctl start sshd 2>/dev/null || sudo service ssh start 2>/dev/null; then
                SSH_STARTED=true
            fi
            sudo systemctl enable ssh 2>/dev/null || sudo systemctl enable sshd 2>/dev/null || true
        fi

        if [ "$SSH_STARTED" = true ]; then
            echo -e "\033[32mSSH server started and enabled.\033[0m"
        else
            echo -e "\033[33mWarning: Failed to start SSH server. Please check service status manually.\033[0m"
        fi
    else
        echo -e "\033[32mSSH server is already running.\033[0m"
    fi
else
    echo "Note: SSH server (sshd) not found. Run 'sudo apt install openssh-server' if needed."
fi

# 4. Virtualization Host Optimizations (ZRAM & KSM)
{{ if .is_virtualization_host }}
echo "--- Virtualization Host Optimizations ---"
if is_root; then
    SUDO_CMD=""
else
    SUDO_CMD="sudo"
fi

# Configure ZRAM
if command -v zramctl >/dev/null 2>&1; then
    if command -v zramctl >/dev/null 2>&1 && grep -qiE "^ID(_LIKE)?=.*fedora" /etc/os-release 2>/dev/null; then
        echo "Configuring ZRAM for Hypervisor (Fedora, zstd, 100%)..."
        $SUDO_CMD mkdir -p /etc/systemd/zram-generator.conf.d
        cat << 'EOF' | $SUDO_CMD tee /etc/systemd/zram-generator.conf.d/zram0.conf > /dev/null
# ZRAM Configuration specifically formulated for Virtualization Hosts (KVM/K8s)
# Compression algorithm zstd provides high compression ratio (~3:1 for text/json/VM memory)
[zram0]
algorithm = zstd
max-compression = true
memory-limit = 100%
EOF
        echo "Restarting ZRAM service to apply changes..."
        if $SUDO_CMD systemctl restart systemd-zram-setup@zram0; then
            echo -e "\033[32mZRAM configured and running.\033[0m"
        else
            echo -e "\033[33mWarning: Failed to restart ZRAM service.\033[0m"
        fi
    elif ! grep -qiE "^ID(_LIKE)?=.*fedora" /etc/os-release 2>/dev/null; then
        echo "Found zram-tools. Configuring ZRAM for Hypervisor (zstd, 50%)..."
        # Backup existing config
        if [ -f /etc/default/zramswap ]; then
            $SUDO_CMD cp /etc/default/zramswap /etc/default/zramswap.bak
        fi

        # Write optimized configuration
        cat << 'EOF' | $SUDO_CMD tee /etc/default/zramswap > /dev/null
# ZRAM Configuration specifically formulated for Virtualization Hosts (KVM/K8s)
# Compression algorithm zstd provides high compression ratio (~3:1 for text/json/VM memory)
ALGO=zstd

# Specify the percentage of RAM that can be compressed.
# Since we are aggressively running VMs, 50% allows us to claw back a lot of space.
PERCENT=50
EOF

        echo "Restarting ZRAM service to apply changes..."
        if $SUDO_CMD systemctl restart zramswap; then
            echo -e "\033[32mZRAM configured and running.\033[0m"
        else
            echo -e "\033[33mWarning: Failed to restart ZRAM service.\033[0m"
        fi
    else
        echo "Note: ZRAM managed by zram-generator-defaults on Fedora. No manual configuration needed."
    fi
fi

# Enable KSM (Kernel Samepage Merging)
if grep -qiE "^ID(_LIKE)?=.*fedora" /etc/os-release 2>/dev/null; then
    # Fedora family: ksm.service manages the kernel KSM driver; ksmtuned.service provides dynamic tuning (optional)
    KSM_FOUND=false
    if systemctl list-unit-files | grep -q "^ksm.service"; then
        KSM_FOUND=true
        echo "Found ksm.service. Enabling Kernel Samepage Merging..."
        if ! systemctl is-active --quiet ksm 2>/dev/null; then
            $SUDO_CMD systemctl enable ksm > /dev/null 2>&1
            if $SUDO_CMD systemctl start ksm; then
                echo -e "\033[32mksm.service started successfully.\033[0m"
            else
                echo -e "\033[33mWarning: Failed to start ksm.service.\033[0m"
            fi
        else
            echo -e "\033[32mksm.service is already running.\033[0m"
        fi
    fi
    if systemctl list-unit-files | grep -q "^ksmtuned.service"; then
        KSM_FOUND=true
        echo "Found ksmtuned.service. Enabling KSM dynamic tuning..."
        if ! systemctl is-active --quiet ksmtuned 2>/dev/null; then
            $SUDO_CMD systemctl enable ksmtuned > /dev/null 2>&1
            if $SUDO_CMD systemctl start ksmtuned; then
                echo -e "\033[32mksmtuned.service started successfully.\033[0m"
            else
                echo -e "\033[33mWarning: Failed to start ksmtuned.service.\033[0m"
            fi
        else
            echo -e "\033[32mksmtuned.service is already running.\033[0m"
        fi
    fi
    if [ "$KSM_FOUND" = false ]; then
        echo "Neither ksm.service nor ksmtuned.service found. Skipping KSM configuration."
    fi
else
    if systemctl list-unit-files | grep -q "ksmtuned.service"; then
        echo "Found ksmtuned. Enabling Kernel Samepage Merging..."
        if ! systemctl is-active --quiet ksmtuned 2>/dev/null; then
            $SUDO_CMD systemctl enable ksmtuned > /dev/null 2>&1
            if $SUDO_CMD systemctl start ksmtuned; then
                echo -e "\033[32mksmtuned started successfully.\033[0m"
            else
                echo -e "\033[33mWarning: Failed to start ksmtuned.\033[0m"
            fi
        else
            echo -e "\033[32mksmtuned is already running.\033[0m"
        fi
    else
        echo "ksmtuned service not found. Skipping KSM configuration."
    fi
fi

# SELinux configuration for KVM/libvirt on Fedora family
SELINUX_OS_ID=""
SELINUX_OS_ID_LIKE=""
if [ -f /etc/os-release ]; then
    SELINUX_OS_ID=$(grep '^ID=' /etc/os-release | cut -d= -f2 | tr -d '"')
    SELINUX_OS_ID_LIKE=$(grep '^ID_LIKE=' /etc/os-release | cut -d= -f2 | tr -d '"')
fi

if [ "$SELINUX_OS_ID" = "fedora" ] || \
   echo "$SELINUX_OS_ID_LIKE" | grep -qiE "(fedora|rhel|rocky)"; then
    echo "--- SELinux KVM/libvirt Configuration (Fedora family) ---"

    if command -v getenforce >/dev/null 2>&1; then
        SELINUX_STATUS=$(getenforce 2>/dev/null || echo "Disabled")
        echo "SELinux status: $SELINUX_STATUS"

        if [ "$SELINUX_STATUS" = "Enforcing" ]; then
            # Restore correct SELinux file contexts for libvirt.
            # After installation, file contexts under /var/lib/libvirt can be mislabeled,
            # causing AVC denials when virtqemud/libvirtd tries to access them.
            if command -v restorecon >/dev/null 2>&1; then
                echo "Restoring SELinux file contexts for /var/lib/libvirt..."
                if $SUDO_CMD restorecon -R /var/lib/libvirt; then
                    echo "SELinux file contexts restored for /var/lib/libvirt."
                else
                    echo "Warning: restorecon failed for /var/lib/libvirt."
                fi
            else
                echo "Warning: restorecon not found. SELinux file contexts not restored."
            fi

            # Set virt_use_nfs boolean if nfs-utils is installed.
            # This boolean is required for libvirt to access NFS-backed storage pools.
            # Only set it when nfs-utils is present to avoid enabling it unnecessarily.
            if rpm -q nfs-utils >/dev/null 2>&1; then
                if command -v setsebool >/dev/null 2>&1; then
                    echo "nfs-utils detected. Setting SELinux boolean virt_use_nfs=on (persistent)..."
                    if $SUDO_CMD setsebool -P virt_use_nfs on; then
                        echo "SELinux boolean virt_use_nfs set to on."
                    else
                        echo "Warning: Failed to set SELinux boolean virt_use_nfs."
                    fi
                else
                    echo "Warning: setsebool not found. Cannot set virt_use_nfs boolean."
                fi
            else
                echo "nfs-utils not installed. Skipping virt_use_nfs boolean."
            fi

            # Check for recent AVC denials related to virtqemud or libvirtd.
            # This is diagnostic only; does not fail if the daemon is not running yet.
            if command -v ausearch >/dev/null 2>&1; then
                echo "Checking for recent AVC denials related to libvirt daemons..."
                AVC_HITS=$(ausearch -m avc -ts recent 2>/dev/null | grep -cE "(virtqemud|libvirtd)" || true)
                if [ "${AVC_HITS:-0}" -gt 0 ]; then
                    echo "Warning: ${AVC_HITS} AVC denial(s) found for virtqemud/libvirtd."
                    echo "Review with: ausearch -m avc -ts recent | grep -E '(virtqemud|libvirtd)'"
                else
                    echo "No recent AVC denials found for virtqemud/libvirtd."
                fi
            else
                echo "Note: ausearch not available. AVC denial check skipped."
            fi
        else
            echo "SELinux is not enforcing ($SELINUX_STATUS). Skipping SELinux configuration."
        fi
    else
        echo "Note: getenforce not found. SELinux not active or not installed."
    fi
fi

# libvirt group membership
# Fedora does not add users to the libvirt group automatically (unlike Debian postinst scripts).
# Running this on Debian is safe: usermod -aG is additive and idempotent when already a member.
LIBVIRT_USER="${USER:-$(logname 2>/dev/null)}"
if getent group libvirt >/dev/null 2>&1; then
    if [ -n "$LIBVIRT_USER" ]; then
        if id -nG "$LIBVIRT_USER" 2>/dev/null | tr ' ' '\n' | grep -qx libvirt; then
            echo "$LIBVIRT_USER is already a member of the libvirt group."
        else
            echo "Adding $LIBVIRT_USER to libvirt group..."
            if $SUDO_CMD usermod -aG libvirt "$LIBVIRT_USER"; then
                echo "Note: $LIBVIRT_USER added to libvirt group. You must log out and back in for group membership to take effect."
            else
                echo "Warning: Failed to add $LIBVIRT_USER to libvirt group."
            fi
        fi
    else
        echo "Warning: Could not determine current user. Skipping libvirt group membership."
    fi
else
    echo "Note: libvirt group does not exist yet (package not installed). Skipping group membership."
fi

# firewalld check for libvirt networking (Fedora family only)
# On Fedora, firewalld manages the libvirt network zone.
# If firewalld is not running, virbr0 fails to start and VMs have no network.
if grep -qiE "^ID(_LIKE)?=.*fedora" /etc/os-release 2>/dev/null; then
    echo "--- firewalld / libvirt networking check (Fedora family) ---"

    if command -v firewall-cmd >/dev/null 2>&1; then
        # Ensure firewalld is enabled (idempotent: only enables if not already enabled)
        if ! systemctl is-enabled --quiet firewalld 2>/dev/null; then
            echo "Enabling firewalld..."
            $SUDO_CMD systemctl enable firewalld
        else
            echo "firewalld is already enabled."
        fi

        # Ensure firewalld is started (idempotent: only starts if not already running)
        if ! systemctl is-active --quiet firewalld 2>/dev/null; then
            echo "Starting firewalld..."
            if $SUDO_CMD systemctl start firewalld; then
                echo "firewalld started successfully."
            else
                echo "Warning: Failed to start firewalld."
            fi
        else
            echo "firewalld is already running."
        fi

        # Verify the libvirt zone exists in firewalld.
        # libvirtd registers the 'libvirt' zone when it starts; only check if libvirt daemon is active.
        if systemctl is-active --quiet libvirtd 2>/dev/null || systemctl is-active --quiet virtqemud 2>/dev/null; then
            if firewall-cmd --get-zones 2>/dev/null | grep -qw libvirt; then
                echo "firewalld libvirt zone is present."
            else
                echo "Warning: libvirt zone not found in firewalld. libvirt networking may be broken."
                echo "  Check: firewall-cmd --get-zones"
            fi
        else
            echo "Note: libvirtd/virtqemud not running yet. Skipping libvirt zone check."
        fi
    else
        echo "Note: firewalld not installed. libvirt networking may fail on Fedora."
        echo "  Install with: sudo dnf install firewalld"
    fi
fi

# tuned profile for virtualization host
if command -v tuned-adm >/dev/null 2>&1; then
    CURRENT_PROFILE=$(tuned-adm active 2>/dev/null | grep -oP '(?<=Current active profile: ).+' || echo "")
    if [ "$CURRENT_PROFILE" = "virtual-host" ]; then
        echo "tuned profile already set to virtual-host."
    else
        echo "Setting tuned profile to virtual-host (was: ${CURRENT_PROFILE:-unknown})..."
        if $SUDO_CMD tuned-adm profile virtual-host; then
            echo "tuned profile set to virtual-host."
        else
            echo "Warning: Failed to set tuned profile."
        fi
    fi
fi
{{ end }}

{{ if and (eq .chezmoi.os "linux") .is_workstation }}
# Google Chrome -- Fedora family only (add official Google repo, then install)
if grep -qiE "^ID(_LIKE)?=.*fedora" /etc/os-release 2>/dev/null; then
    echo "--- Google Chrome ---"
    if ! command -v google-chrome-stable >/dev/null 2>&1; then
        CHROME_REPO="/etc/yum.repos.d/google-chrome.repo"
        if [ ! -f "$CHROME_REPO" ]; then
            echo "Adding Google Chrome repo..."
            cat << 'EOF' | $SUDO_CMD tee "$CHROME_REPO" > /dev/null
[google-chrome]
name=google-chrome
baseurl=https://dl.google.com/linux/chrome/rpm/stable/x86_64
enabled=1
gpgcheck=1
gpgkey=https://dl.google.com/linux/linux_signing_key.pub
EOF
        fi
        echo "Installing Google Chrome..."
        if $SUDO_CMD dnf install -y google-chrome-stable; then
            echo "Google Chrome installed."
        else
            echo "Warning: Failed to install Google Chrome."
        fi
    else
        echo "Google Chrome already installed."
    fi
fi

{{ end }}

{{ end }}